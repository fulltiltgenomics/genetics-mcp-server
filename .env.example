# Genetics API URL (the REST API providing data)
GENETICS_API_URL=http://0.0.0.0:2000/api

# BigQuery API URL (for direct SQL queries)
BIGQUERY_API_URL=http://0.0.0.0:8080

# LLM API Keys (for chat service, only one needed and both are optional for MCP-only usage)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Web search (optional)
TAVILY_API_KEY=tvly-...

# Literature search backend: "europepmc" (default) or "perplexity" - perplexity requires API key
LITERATURE_SEARCH_BACKEND=perplexity
PERPLEXITY_API_KEY=pplx-...

# Public URL of the chat API (for generating download links shown to users)
CHAT_PUBLIC_URL=http://localhost:4000

# Download storage for tool result TSV files
DOWNLOAD_STORAGE_PATH=/mnt/disks/data/downloads
DOWNLOAD_TTL_SECONDS=2592000  # 30 days

# Database paths
LLM_CONFIG_DB=/mnt/disks/data/llm_config.db
CHAT_HISTORY_DB=/mnt/disks/data/chat_history.db

# Authentication (optional) - requires IAP or oauth2-proxy to set X-Goog-Authenticated-User-Email header, or custom tokens
REQUIRE_AUTH=false

# MCP transport security (set to true only for development)
MCP_DISABLE_TRANSPORT_SECURITY=false

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# External MCP servers to proxy (comma-separated, always-on)
# Format: URL or URL|AUTH_TOKEN for servers requiring authentication
# Tools from these servers are always available regardless of tool_profile
# - Open Targets Platform MCP: gene-disease associations, drug targets, GraphQL API
EXTERNAL_MCP_SERVERS=https://mcp.platform.opentargets.org

# RAG MCP server (only included when tool_profile is "rag" or unset)
# Format: URL or URL|AUTH_TOKEN
# RAG_MCP_SERVER=http://...

# Tools to exclude from proxying (comma-separated, useful to avoid duplicates)
EXTERNAL_MCP_EXCLUDE_TOOLS=""

# Optional tools (disabled by default)
ENABLE_CREDIBLE_SETS_STATS=false
ENABLE_PHENOTYPE_REPORT=false

# Subagent settings (disabled by default)
ENABLE_SUBAGENTS=false
SUBAGENT_MODEL=                        # defaults to fast_model (claude-haiku-4-5)
SUBAGENT_TIMEOUT=120                   # seconds per subagent
SUBAGENT_ALLOWED_PATHS=                # comma-separated directories subagents can read/write
ENABLE_SCRIPT_EXECUTION=false          # allow subagents to execute Python/R/bash scripts
SUBAGENT_SCRIPT_TIMEOUT=30             # seconds per script execution
